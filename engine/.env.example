# Sankofa Configuration
APP_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:3000
LOG_LEVEL=info

# Database (SQLite)
SQLITE_FILE=sankofa.db

# Analytics (ClickHouse)
CLICKHOUSE_ADDR=127.0.0.1:9000
CLICKHOUSE_DB=default
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# Security
# Generate a secure key for JWT/Sessions if needed later
API_SECRET=


# Admin Setup
ADMIN_EMAIL=myadmin@example.com
ADMIN_PASSWORD=my_secure_password
ADMIN_ORG_NAME="My Company Name"
ADMIN_PROJECT_NAME="My Production App"
GEOIP_DB_PATH="Add your GeoLite2-City.mmdb file path"


# Backblaze B2
B2_KEY_ID=
B2_APP_KEY=
B2_BUCKET_NAME=
B2_ENDPOINT=
